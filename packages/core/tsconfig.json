{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "outDir": "./dist",
    "rootDir": "./src", // This tells TS to treat 'src' as the root of the code
    "declaration": true,
    "sourceMap": true,
    "allowJs": true, // Required to process wasm_exec.js
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "types": ["node"]
  },
  "include": ["src/**/*"], // Ensure it captures everything in src
  "exclude": ["node_modules", "dist"]
}
