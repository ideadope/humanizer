{
  "name": "@ideadope/humanizer",
  "version": "1.1.10",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/index.js",
    "dist/index.d.ts",
    "dist/wasm_exec.js"
  ],
  "exports": {
    ".": "./dist/index.js",
    "./wasm_exec": "./dist/wasm_exec.js"
  },
  "sideEffects": [
    "./dist/wasm_exec.js"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "build:wasm": "tinygo build -o dist/humanizer.wasm -target wasm -no-debug src/main.go",
    "build:core": "tsc -p ./tsconfig.json && cp src/wasm_exec.js dist/wasm_exec.js",
    "build": "pnpm run clean && pnpm run build:wasm && pnpm run build:core"
  },
  "devDependencies": {
    "@types/node": "^25.5.2"
  }
}
