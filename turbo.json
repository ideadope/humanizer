{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build:wasm": {
      "inputs": ["src/**/*.go"],
      "outputs": ["dist/humanizer.wasm"],
      "cache": true
    },
    "build:core": {
      "dependsOn": ["build:wasm"],
      "inputs": ["src/**/*.ts", "src/wasm_exec.js"],
      "outputs": ["dist/**"],
      "cache": true
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    }
  }
}
